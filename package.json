{
  "name": "@kongatc/design-system-mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "Git-backed MCP server for React/TSX design system knowledge and drift detection.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "design-system-mcp": "./dist/src/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "package.json"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "design-system",
    "react",
    "tsx"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && node dist/src/index.js",
    "start": "node dist/src/index.js",
    "prepack": "npm run build",
    "pack:dry-run": "npm pack --dry-run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  }
}
